<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Pago exitoso - Tourism AI</title>
</head>
<body style="margin:0;padding:0;background-color:#12131C;font-family:Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#12131C;">
    <tr>
      <td align="center" style="padding:40px 16px;">

        <!-- Card -->
        <table width="480" cellpadding="0" cellspacing="0" border="0"
               style="max-width:480px;width:100%;background-color:#1A1B2E;border-radius:16px;border:1px solid #183524;">

          <!-- Top accent line (green) -->
          <tr>
            <td style="height:3px;background-color:#22C55E;border-radius:16px 16px 0 0;font-size:0;line-height:0;">&nbsp;</td>
          </tr>

          <tr><td style="height:36px;font-size:0;">&nbsp;</td></tr>

          <!-- Check icon -->
          <tr>
            <td align="center" style="padding:0 40px;">
              <table cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td width="72" height="72" align="center" valign="middle"
                      style="width:72px;height:72px;border-radius:50%;background-color:#0F2418;border:2px solid #22C55E;text-align:center;vertical-align:middle;">
                    <span style="font-size:30px;color:#22C55E;line-height:72px;font-weight:bold;">✓</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr><td style="height:20px;font-size:0;">&nbsp;</td></tr>

          <!-- Title -->
          <tr>
            <td align="center" style="padding:0 40px;">
              <p style="margin:0;font-size:22px;font-weight:bold;color:#FFFFFF;font-family:Arial,sans-serif;">
                Pago exitoso
              </p>
            </td>
          </tr>

          <tr><td style="height:8px;font-size:0;">&nbsp;</td></tr>

          <!-- Subtitle -->
          <tr>
            <td align="center" style="padding:0 40px;">
              <p style="margin:0;font-size:14px;color:#8B90B8;font-family:Arial,sans-serif;">
                Tu transacción fue procesada correctamente
              </p>
            </td>
          </tr>

          <tr><td style="height:14px;font-size:0;">&nbsp;</td></tr>

          <!-- Success pill -->
          <tr>
            <td align="center" style="padding:0 40px;">
              <table cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="background-color:#102417;border:1px solid #1E7A46;border-radius:99px;padding:5px 14px;">
                    <p style="margin:0;font-size:12px;color:#4ADE80;font-family:Arial,sans-serif;">
                      ✅ Plan activado correctamente
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr><td style="height:24px;font-size:0;">&nbsp;</td></tr>

          <!-- Details box -->
          <tr>
            <td style="padding:0 32px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0"
                     style="background-color:#16172A;border-radius:12px;border:1px solid #1E2A3D;">

                <tr><td style="height:14px;font-size:0;">&nbsp;</td></tr>

                <!-- Referencia -->
                <tr>
                  <td style="padding:6px 16px;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="font-size:13px;color:#8B90B8;font-family:Arial,sans-serif;">
                          Referencia
                        </td>
                        <td align="right"
                            style="font-size:13px;color:#FFFFFF;font-weight:bold;font-family:Arial,sans-serif;">
                          {{invoiceNumber}}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <tr>
                  <td style="padding:0 16px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="height:1px;background-color:#1F2040;font-size:0;">&nbsp;</td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <!-- Plan -->
                <tr>
                  <td style="padding:6px 16px;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="font-size:13px;color:#8B90B8;font-family:Arial,sans-serif;">
                          Plan
                        </td>
                        <td align="right"
                            style="font-size:13px;color:#FFFFFF;font-weight:bold;font-family:Arial,sans-serif;">
                          {{plan}}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <tr>
                  <td style="padding:0 16px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="height:1px;background-color:#1F2040;font-size:0;">&nbsp;</td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <!-- Monto -->
                <tr>
                  <td style="padding:6px 16px;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="font-size:13px;color:#8B90B8;font-family:Arial,sans-serif;">
                          Monto pagado
                        </td>
                        <td align="right"
                            style="font-size:15px;color:#4ADE80;font-weight:bold;font-family:Arial,sans-serif;">
                          {{currency}} {{amount}}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <tr>
                  <td style="padding:0 16px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="height:1px;background-color:#1F2040;font-size:0;">&nbsp;</td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <!-- Fecha -->
                <tr>
                  <td style="padding:6px 16px;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="font-size:13px;color:#8B90B8;font-family:Arial,sans-serif;">
                          Fecha
                        </td>
                        <td align="right"
                            style="font-size:13px;color:#FFFFFF;font-weight:bold;font-family:Arial,sans-serif;">
                          {{date}}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <tr>
                  <td style="padding:0 16px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="height:1px;background-color:#1F2040;font-size:0;">&nbsp;</td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <!-- Estado -->
                <tr>
                  <td style="padding:6px 16px;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="font-size:13px;color:#8B90B8;font-family:Arial,sans-serif;">
                          Estado
                        </td>
                        <td align="right">
                          <span style="display:inline-block;background-color:#102417;border:1px solid #22C55E;color:#4ADE80;font-size:11px;font-weight:bold;font-family:Arial,sans-serif;padding:3px 10px;border-radius:99px;">
                            ● Aprobado
                          </span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>

                <tr><td style="height:14px;font-size:0;">&nbsp;</td></tr>

              </table>
            </td>
          </tr>

          <tr><td style="height:28px;font-size:0;">&nbsp;</td></tr>

          <!-- CTA -->
          <tr>
            <td align="center" style="padding:0 32px;">
              <a href="{{dashboardUrl}}"
                 style="display:inline-block;background-color:#22C55E;color:#FFFFFF;text-decoration:none;font-size:14px;font-weight:bold;font-family:Arial,sans-serif;padding:12px 26px;border-radius:10px;">
                Ir al dashboard
              </a>
            </td>
          </tr>

          <tr><td style="height:24px;font-size:0;">&nbsp;</td></tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding:0 32px;">
              <p style="margin:0;font-size:11px;color:#5E6285;font-family:Arial,sans-serif;">
                Gracias por confiar en Tourism AI ·
                <a href="mailto:soporte@tourism-ai.com"
                   style="color:#22C55E;text-decoration:none;">
                  soporte@tourism-ai.com
                </a>
              </p>
            </td>
          </tr>

          <tr><td style="height:32px;font-size:0;">&nbsp;</td></tr>

        </table>
        <!-- /Card -->

      </td>
    </tr>
  </table>

</body>
</html>